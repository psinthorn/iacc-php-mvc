{
    "name": "psinthorn/iacc-php-mvc",
    "description": "iACC - Accounting & Business Management System",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "mpdf/mpdf": "^8.2",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "classmap": [
