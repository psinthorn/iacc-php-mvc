.dockerignore
docker-compose.override.yml

# Logs
*.log
logs/
error_log

# Temporary files
tmp/
temp/
*.tmp

# Node modules (if any)
node_modules/
npm-debug.log

# Composer (if added later)
vendor/
composer.lock

