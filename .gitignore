.env.production.local
database.sqlite
version.json

# Keep but ignore content of these directories
upload/*
!upload/.gitkeep
file/*
!file/.gitkeep

# Product price lists (large files from distributors)
products/

# Keep Docker configuration
!docker/
!docker/**

# But DO track migration SQL files
!database/migrations/*.sql
!migrations/**/*.sql
templates/tour-company-demo/data/template.db
